---
import Base from '../layouts/Base.astro';
import { REPOS, PROJECTS } from '../data/site';
import Eyebrow from '../components/Eyebrow.astro';
import CTABand from '../components/CTABand.astro';

interface RepoData {
  name: string;
  description: string;
  url: string;
  stars: number;
  language: string;
}

const repos: RepoData[] = [];
for (const repo of REPOS) {
  try {
    const response = await fetch(`https://api.github.com/repos/${repo}`);
    if (response.ok) {
      const data = await response.json();
      repos.push({ name: data.name, description: data.description || '', url: data.html_url, stars: data.stargazers_count, language: data.language || 'Unknown' });
    }
  } catch { console.error(`Failed to fetch repo ${repo}`); }
}
repos.sort((a, b) => b.stars - a.stars);
---

<Base title="Repositories" description="Open-source projects and code repositories.">
  <section class="relative py-24 border-b border-ink/10 bg-paper">
    <div class="max-w-5xl mx-auto px-6">
      <Eyebrow num="01" label="Repositories" class="mb-3" />
      <h1 class="ghost-num text-[9rem] right-0 top-[-2rem]" aria-hidden="true">01</h1>
      <h1 class="h-display text-4xl md:text-5xl text-ink mb-6 pr-48 reveal">Open-source projects</h1>
      <p class="text-ink-soft max-w-xl leading-relaxed reveal reveal-2">
        Key repositories on GitHub. Built for reproducibility, interoperability, and open science.
      </p>
    </div>
  </section>

  <section class="py-20 bg-paper border-b border-ink/10">
    <div class="max-w-5xl mx-auto px-6">
      {repos.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {repos.map((repo) => (
            <a href={repo.url} target="_blank" rel="noopener" class="group block bg-paper p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow duration-200 border-t-2 border-transparent hover:border-saffron">
              <div class="flex items-start justify-between gap-4 mb-2">
                <h3 class="font-display text-lg font-semibold text-ink group-hover:text-saffron transition-colors">{repo.name}</h3>
                <span class="label-mono text-slate whitespace-nowrap flex items-center gap-1.5"><span>⭐</span>{repo.stars.toLocaleString()}</span>
              </div>
              <p class="text-sm text-ink-soft mb-3 line-clamp-2">{repo.description}</p>
              <div class="flex items-center justify-between text-xs">
                <span class="bg-cream px-3 py-1 rounded-sm text-slate font-medium">{repo.language}</span>
                <span class="text-saffron group-hover:text-saffron-bright transition-colors">View on GitHub →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-ink-soft">Loading repositories...</p>
      )}
    </div>
  </section>

  {/* Related projects */}
  <section class="py-20 bg-cream border-b border-ink/10">
    <div class="max-w-5xl mx-auto px-6">
      <Eyebrow num="02" label="Related" class="mb-8" />
      <h2 class="font-display text-2xl font-semibold text-ink mb-8">Key projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {PROJECTS.slice(0, 3).map((p) => (
          <a href={p.href} target="_blank" rel="noopener" class="group block border-t-2 border-ink/80 pt-5 hover:border-saffron transition-colors">
            <h3 class="font-display text-lg font-semibold text-ink group-hover:text-saffron transition-colors">{p.name}</h3>
            <p class="text-sm text-ink-soft mt-1">{p.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand />
</Base>

<style is:global>
  .ghost-num { position: absolute; font-family: var(--font-display); font-weight: 700; color: var(--color-ink); opacity: 0.06; pointer-events: none; user-select: none; line-height: 1; }
</style>
