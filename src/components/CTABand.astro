---
interface Props {
  heading?: string;
  sub?: string;
  email?: string;
}

const { heading = "Got a problem that needs shipping?", sub = 'Let\'s talk — discovery call on me.', email = 'sarthak@verysafe.ai' } = Astro.props;
---

<section class="bg-ink text-paper relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03]">
    <svg viewBox="0 0 1200 400" preserveAspectRatio="none" class="w-full h-full">
      <path d="M-100,80 C150,20 350,150 600,100 S900,200 1300,60" fill="none" stroke="#e87228" stroke-width="1" stroke-dasharray="8 6" />
      <path d="M-100,220 C250,160 450,280 750,180 S1000,260 1300,200" fill="none" stroke="#e87228" stroke-width="1.2" stroke-dasharray="10 4" />
    </svg>
  </div>
  <div class="max-w-5xl mx-auto px-6 py-20 text-center relative z-10">
    <h2 class="h-display text-3xl md:text-4xl mb-4">{heading}</h2>
    <p class="text-cream mb-8 max-w-xl mx-auto">{sub}</p>
    <a href={`mailto:${email}`} class="inline-block bg-saffron text-paper font-medium px-7 py-3 rounded-sm hover:bg-saffron-bright transition-colors duration-200">
      {email}
    </a>
  </div>
</section>
