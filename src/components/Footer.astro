---
import { SITE } from '../data/site';
---

<footer class="border-t border-ink/10 bg-paper">
  <div class="max-w-5xl mx-auto px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">
      <div>
        <h3 class="font-display font-bold text-lg mb-3 text-ink">{SITE.title}</h3>
        <p class="text-sm text-ink-soft leading-relaxed max-w-xs">
          {SITE.description}
        </p>
      </div>
      <div>
        <h4 class="label-mono text-slate mb-4">Explore</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/publications/" class="link-ink text-ink-soft hover:text-saffron transition-colors">Publications</a></li>
          <li><a href="/cv/" class="link-ink text-ink-soft hover:text-saffron transition-colors">CV</a></li>
          <li><a href="/resume_sarthak.pdf" target="_blank" rel="noopener" class="link-ink text-ink-soft hover:text-saffron transition-colors">Résumé (PDF)</a></li>
          <li><a href="/repositories/" class="link-ink text-ink-soft hover:text-saffron transition-colors">Repositories</a></li>
        </ul>
      </div>
      <div>
        <h4 class="label-mono text-slate mb-4">Connect</h4>
        <a href={`mailto:${SITE.email}`} class="link-ink text-ink-soft hover:text-saffron transition-colors text-sm block mb-4">
          {SITE.email}
        </a>
        <div class="flex gap-5 text-sm">
          <a href={SITE.social.github} class="text-slate hover:text-saffron transition-colors" target="_blank" rel="noopener">GitHub</a>
          <a href={SITE.social.linkedin} class="text-slate hover:text-saffron transition-colors" target="_blank" rel="noopener">LinkedIn</a>
          <a href={SITE.social.scholar} class="text-slate hover:text-saffron transition-colors" target="_blank" rel="noopener">Scholar</a>
          <a href={SITE.social.orcid} class="text-slate hover:text-saffron transition-colors" target="_blank" rel="noopener">ORCID</a>
        </div>
      </div>
    </div>
    <div class="border-t border-ink/10 pt-7 text-xs text-slate tracking-wide">
      &copy; {new Date().getFullYear()} Sarthak Pati. All rights reserved.
    </div>
  </div>
</footer>
